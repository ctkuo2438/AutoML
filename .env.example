# Environment: development | production
ENV=development

# Database
# SQLite (default, good for local dev):
DATABASE_URL=sqlite:///./automl.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/automl

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production (app refuses to start if still "changeme")
SECRET_KEY=changeme

# File storage directories
UPLOAD_DIR=uploads
MODEL_DIR=models

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
